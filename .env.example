NEXT_PUBLIC_INSFORGE_URL=https://your-project.region.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://your-project.insforge.site

# Planning chat provider. Set FEATURE_PLANNING_PROVIDER=codex to route
# interactive request planning through the InsForge Compute Codex runner.
FEATURE_PLANNING_PROVIDER=insforge
AI_PROVIDER=insforge
INSFORGE_AI_MODEL=openai/gpt-4o-mini
# AI_GATEWAY_API_KEY=

# Required when FEATURE_PLANNING_PROVIDER=codex.
