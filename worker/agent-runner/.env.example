PORT=8080
FORKABLE_AGENT_RUNNER_ENABLED=false
FORKABLE_AGENT_RUNNER_POLL_MS=5000
FORKABLE_RUNNER_WEBHOOK_SECRET=
# POST /scheduled-tasks/tick with Authorization: Bearer $FORKABLE_RUNNER_WEBHOOK_SECRET
# to claim and evaluate due scheduled_agent_tasks. Limit is per tick.
FORKABLE_SCHEDULED_TASK_TICK_LIMIT=4

INSFORGE_URL=
INSFORGE_API_KEY=

# Codex auth. Prefer CODEX_API_KEY for automation. To use your ChatGPT/Codex
# subscription on a trusted private runner, seed CODEX_AUTH_JSON_B64 from
# ~/.codex/auth.json after running `codex login`.
CODEX_API_KEY=
CODEX_AUTH_JSON_B64=
# Use these instead of CODEX_AUTH_JSON_B64 when the encoded auth file is over
# InsForge Compute's per-env-var size limit.
# CODEX_AUTH_JSON_B64_PART_001=
# CODEX_AUTH_JSON_B64_PART_002=
FORKABLE_CODEX_HOME=/app/.forkable-codex-home
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=low
FORKABLE_CODEX_SCHEDULED_TIMEOUT_MS=180000

FORKABLE_TARGET_REPO_URL=
FORKABLE_TARGET_REPO_REF=main
FORKABLE_TARGET_REPO_SUBDIR=
FORKABLE_WORKDIR=/app/.forkable-agent-runs
FORKABLE_PUSH_BRANCH=true
FORKABLE_AUTO_MERGE=true

GITHUB_TOKEN=
GIT_AUTHOR_NAME=Forkable Agent
GIT_AUTHOR_EMAIL=agent@forkable.site

NIA_API_KEY=
HYPERSPELL_API_KEY=
HYPERSPELL_USER_ID=

FORKABLE_CREATE_BACKEND_BRANCH=false
FORKABLE_REQUIRE_BACKEND_BRANCH=false
# InsForge CLI auth for backend branches and deployments inside Compute.
# Seed from ~/.insforge/credentials.json and ~/.insforge/config.json on a trusted machine.
INSFORGE_CLI_CREDENTIALS_JSON_B64=
INSFORGE_CLI_CONFIG_JSON_B64=
INSFORGE_ACCESS_TOKEN=
INSFORGE_PROJECT_ID=

FORKABLE_DEPLOY_PREVIEW=false
FORKABLE_DEPLOY_PRODUCTION=true
FORKABLE_CHECK_COMMANDS=
